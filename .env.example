# ArgusMonitor Environment Configuration

# Security - CHANGE THIS in production
ARGUS_SECRET_KEY=change-me-in-production-use-a-real-secret-key

# AI Features (optional - platform works without this, using built-in fallback responses)
# For OpenRouter/OmniRoute/OpenAI-compatible gateways, set ARGUS_OPENAI_BASE_URL accordingly.
ARGUS_OPENAI_API_KEY=
ARGUS_OPENAI_MODEL=gpt-4o-mini
ARGUS_OPENAI_BASE_URL=https://api.openai.com/v1
ARGUS_OPENAI_APP_NAME=ArgusMonitor
ARGUS_OPENAI_SITE_URL=
ARGUS_AGENT_SHARED_TOKEN=argus-agent-dev-token
ARGUS_DEMO_MODE=false

# Database (set via docker-compose.yml environment block)
# ARGUS_DATABASE_URL=<set-in-compose>
# ARGUS_DATABASE_URL_SYNC=<set-in-compose>

# Redis (defaults work with docker-compose)
# ARGUS_REDIS_URL=redis://redis:6379/0

# Standalone host agents can use optional richer service collectors:
# ARGUS_POSTGRES_DSN=postgresql://argus:arguspass@127.0.0.1:5432/appdb
# ARGUS_MYSQL_DSN=mysql://argus:arguspass@127.0.0.1:3306/appdb
# ARGUS_RABBITMQ_API_URL=http://127.0.0.1:15672
# ARGUS_RABBITMQ_API_USERNAME=argus
# ARGUS_RABBITMQ_API_PASSWORD=arguspass
