# Vordr Environment Configuration

# Security - CHANGE THIS in production
VORDR_SECRET_KEY=change-me-in-production-use-a-real-secret-key
VORDR_AGENT_SHARED_TOKEN=vordr-agent-dev-token

# Compose defaults for the core self-hosted stack
POSTGRES_USER=argus
POSTGRES_PASSWORD=changeme
POSTGRES_DB=argus
VORDR_LICENSE_KEY=
VORDR_CORS_ORIGINS=http://localhost:8080,http://localhost:5173,http://frontend:8080

# AI Features (optional - platform works without this, using built-in fallback responses)
# For OpenRouter/OmniRoute/OpenAI-compatible gateways, set VORDR_OPENAI_BASE_URL accordingly.
VORDR_OPENAI_API_KEY=
VORDR_OPENAI_MODEL=gpt-4o-mini
VORDR_OPENAI_BASE_URL=https://api.openai.com/v1
VORDR_OPENAI_APP_NAME=Vordr
VORDR_OPENAI_SITE_URL=
VORDR_DEMO_MODE=false

# Database (set via docker-compose.yml environment block)
# VORDR_DATABASE_URL=<set-in-compose>
# VORDR_DATABASE_URL_SYNC=<set-in-compose>

# Redis (defaults work with docker-compose)
# VORDR_REDIS_URL=redis://redis:6379/0

# Standalone host agents can use optional richer service collectors:
# VORDR_POSTGRES_DSN=postgresql://argus:arguspass@127.0.0.1:5432/appdb
# VORDR_MYSQL_DSN=mysql://argus:arguspass@127.0.0.1:3306/appdb
# VORDR_RABBITMQ_API_URL=http://127.0.0.1:15672
# VORDR_RABBITMQ_API_USERNAME=argus
# VORDR_RABBITMQ_API_PASSWORD=arguspass
